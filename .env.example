# Supabase Postgres connection (direct, port 5432, NOT pooler 6543)
# Get from: Project Settings → Database → Connection string → URI tab
# Replace [YOUR-PASSWORD] with your database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# Anthropic API key for generation
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key for embeddings
# Get from: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=pa-...

# Cohere API key for reranking
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=...